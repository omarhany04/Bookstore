# Backend environment variables
# Vercel provides PORT automatically in production.
# For local development only, you can set PORT=5000 in your untracked backend/.env file.
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_SUPABASE_DB_PASSWORD@aws-1-eu-west-1.pooler.supabase.com:6543/postgres
JWT_SECRET=replace-with-a-long-random-secret

# Chat providers
GEMINI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=

# Chat models
GEMINI_MODEL=gemini-2.5-flash-lite
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
GROQ_MODEL=llama-3.1-8b-instant
